{
  "name": "ink-player",
  "version": "2.0.6",
  "description": "Playing interactive fiction powered by Inkle's ink engine",
  "main": "main.js",
  "scripts": {
    "clean": "rm -rf node_modules dist/main.js dist/styles.css package-lock.json bun.lock",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "biome check --write --error-on-warnings . && tsc --noEmit",
    "release": "bun run scripts/release.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tsconfig/bun": "^1.0.10",
    "@tsconfig/vite-react": "^7.0.2",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "^1.3.13",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "obsidian": "^1.12.3",
    "tslib": "2.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@inkweave/core": "^1.5.1",
    "@inkweave/plugins": "^1.5.1",
    "@inkweave/react": "^1.5.1",
    "inkjs": "^2.4.0",
    "mustache": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "obsidian": ">=0.15.0"
  }
}
