{
  "name": "ink-player",
  "version": "2.0.7",
  "description": "Playing interactive fiction powered by Inkle's ink engine",
  "main": "main.js",
  "scripts": {
    "clean": "rm -rf node_modules dist/main.js dist/styles.css package-lock.json bun.lock",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "biome check --write --error-on-warnings . && tsc --noEmit",
    "release": "bun run scripts/release.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@tsconfig/bun": "^1.0.0",
    "@tsconfig/vite-react": "^7.0.0",
    "@types/mustache": "^4.2.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "bun-types": "^1.3.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.0",
    "obsidian": "^1.12.0",
    "tslib": "^2.4.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@inkweave/core": "2.0.4",
    "@inkweave/plugins": "2.0.4",
    "@inkweave/react": "2.0.4",
    "mustache": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0"
  },
  "peerDependencies": {
    "obsidian": ">=0.15.0"
  }
}
