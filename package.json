{
  "name": "ink-player",
  "version": "2.0.3",
  "description": "Playing interactive fiction powered by Inkle's ink engine",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "biome check --write --error-on-warnings . && tsc --noEmit",
    "release": "bun run scripts/release.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.3",
    "jsdom": "^29.0.2",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@inkweave/core": "^1.3.2",
    "@inkweave/plugins": "^1.3.2",
    "@inkweave/react": "^1.3.2",
    "inkjs": "^2.4.0",
    "mustache": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "obsidian": ">=0.15.0"
  }
}
