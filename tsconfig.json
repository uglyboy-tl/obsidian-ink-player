{
	"compilerOptions": {
		"baseUrl": "src",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"allowJs": true,
		"esModuleInterop": true,
		"noImplicitAny": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"lib": ["DOM", "ES5", "ES6", "ES7"],
		"jsx": "react-jsx",
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "src/__tests__", "src/**/*.test.ts", "src/**/*.spec.ts", "src/packages", "src/hooks", "src/lib", "src/components/InkStory.tsx", "src/components/InkChoices.tsx", "src/components/InkContents.tsx", "src/components/InkImage.tsx"]
}
